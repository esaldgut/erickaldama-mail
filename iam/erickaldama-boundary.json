{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowProjectServices",
      "Effect": "Allow",
      "Action": [
        "route53:*", "ses:*", "s3:*", "dynamodb:*", "lambda:*",
        "sns:*", "sqs:*", "kms:*", "cloudwatch:*", "logs:*", "events:*", "ssm:*", "iam:*", "cloudformation:*"
      ],
      "Resource": "*"
    },
    {
      "Sid": "DenyEscalationAndOutOfScope",
      "Effect": "Deny",
      "Action": [
        "route53domains:*", "ec2:*", "rds:*", "organizations:*",
        "iam:PutUserPermissionsBoundary", "iam:PutRolePermissionsBoundary",
        "iam:DeleteUserPermissionsBoundary", "iam:DeleteRolePermissionsBoundary"
      ],
      "Resource": "*"
    },
    {
      "Sid": "DenyCreateUserExceptMailClientPrincipals",
      "Effect": "Deny",
      "Action": [
        "iam:CreateUser", "iam:CreateAccessKey"
      ],
      "NotResource": [
        "arn:aws:iam::367707589526:user/mail-client-read",
        "arn:aws:iam::367707589526:user/mail-sender"
      ]
    }
  ]
}
